{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./packages",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@steel-core/core": ["./packages/core/src/parser.ts"],
      "@steel-core/generator-python": ["./packages/generators/python/src/index.ts"],
      "@steel-core/generator-typescript": ["./packages/generators/typescript/src/index.ts"],
      "@steel-core/mcp-server": ["./packages/mcp-server/src/index.ts"]
    }
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
