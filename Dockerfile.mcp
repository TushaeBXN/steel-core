FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json tsconfig.json ./
COPY packages/ packages/
RUN npm ci
RUN npm run build

FROM node:20-alpine AS runtime
RUN apk add --no-cache python3 py3-pip && ln -sf python3 /usr/bin/python
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001
RUN mkdir -p /sandbox && chown nodejs:nodejs /sandbox
WORKDIR /app
COPY --from=builder --chown=nodejs:nodejs /app/packages/mcp-server/dist ./dist
COPY --from=builder --chown=nodejs:nodejs /app/node_modules ./node_modules
USER nodejs
ENV NODE_ENV=production
ENV SANDBOX_TIMEOUT=5000
ENV SANDBOX_MEMORY_LIMIT=100
CMD ["node", "dist/index.js"]
