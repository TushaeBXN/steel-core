{
  "name": "steel-core",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "packages/generators/*"],
  "scripts": {
    "build": "tsc --build",
    "test": "jest --passWithNoTests",
    "cli": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@steel-core/core$": "<rootDir>/packages/core/src/parser.ts",
      "^@steel-core/generator-python$": "<rootDir>/packages/generators/python/src/index.ts",
      "^@steel-core/generator-typescript$": "<rootDir>/packages/generators/typescript/src/index.ts",
      "^@steel-core/generator-go$": "<rootDir>/packages/generators/go/src/index.ts",
      "^@steel-core/generator-ruby$": "<rootDir>/packages/generators/ruby/src/index.ts",
      "^@steel-core/generator-java$": "<rootDir>/packages/generators/java/src/index.ts",
      "^\\.\\./\\.\\./generators/python/src/index$": "<rootDir>/packages/generators/python/src/index.ts",
      "^\\.\\./\\.\\./generators/typescript/src/index$": "<rootDir>/packages/generators/typescript/src/index.ts"
    }
  },
  "license": "MIT"
}
